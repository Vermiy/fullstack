generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
  USER
  ADMIN
}

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  password String
  role     UserRoles @default(USER)
}

model Book {
  id        Int    @id @default(autoincrement())
  name      String
  author    String
  pageCount Int
}
